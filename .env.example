# Minecraft
MC_PORT=XXXXX
# Optional: pin Minecraft version (e.g. 1.19). Omit to auto-detect from server.
# MC_VERSION=1.19

# Provider — openai | openrouter | anthropic (default: openai)
LLM_PROVIDER=openai
# Embeddings provider — only openai supported (ChromaDB requires stable embeddings)
EMBEDDING_PROVIDER=openai

# API keys — set only what your chosen provider needs
OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...
# ANTHROPIC_API_KEY=sk-ant-...

# Models
ACTION_MODEL=gpt-5.4-mini
CURRICULUM_MODEL=gpt-5.4-mini
CURRICULUM_QA_MODEL=gpt-5.4-nano
CRITIC_MODEL=gpt-5.4-mini
SKILL_MODEL=gpt-5.4-nano
EMBEDDING_MODEL=text-embedding-3-small

# Feature flags
ACTION_ADVANCED_PRIMITIVES=true

# Game mode — determines survival override behavior
GAME_MODE=creative  # "survival" | "creative"
